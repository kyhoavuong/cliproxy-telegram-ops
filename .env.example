# Copy to .env and replace every placeholder before running the stack.
# Never commit the real .env file.

# CLIProxyAPI / management
CPA_MANAGEMENT_KEY=replace-with-management-secret
CLIPROXY_MANAGEMENT_TOKEN=
CLIPROXY_MANAGEMENT_BASE_URL=http://cliproxy:3000/v0/management

# Usage Keeper dashboard password
USAGE_KEEPER_PASSWORD=replace-with-strong-password

# Cloudflare Tunnel
CLOUDFLARED_TOKEN=replace-with-cloudflare-tunnel-token

# Telegram Alerts
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-private-chat-id
TELEGRAM_ALLOWED_CHAT_IDS=replace-with-private-chat-id
TELEGRAM_ALLOWED_USER_IDS=replace-with-telegram-user-id

# Telegram polling and cache tuning
ALERT_INTERVAL_SECONDS=15
ALERT_COMMAND_POLL_SECONDS=0.25
TELEGRAM_GET_UPDATES_TIMEOUT_SECONDS=5
ALERT_SNAPSHOT_MAX_AGE_SECONDS=120
USAGE_REPORT_CACHE_SECONDS=20
CAPACITY_CHECK_FAST_CACHE_SECONDS=60
QUOTA_MANAGEMENT_FAST_CACHE_SECONDS=60
ERRORS_FAST_CACHE_SECONDS=60

# Alert thresholds
ALERT_QUOTA_WARN_PERCENT=85
ALERT_QUOTA_CRITICAL_PERCENT=98

# Usage Keeper integration
USAGE_KEEPER_BASE_URL=http://usage-keeper:8080/usage

# Auth quota inspection
AUTH_QUOTA_REFRESH_BEFORE_CHECK=true
AUTH_QUOTA_REFRESH_COOLDOWN_SECONDS=300
AUTH_QUOTA_INSPECTION_WAIT_SECONDS=60
AUTH_QUOTA_HTTP_TIMEOUT_SECONDS=8
AUTH_QUOTA_ENFORCER_COOLDOWN_SECONDS=300

# Change watch / operator action behavior
CHANGE_WATCH_INTERVAL_SECONDS=2
CHANGE_NOTIFICATION_DEBOUNCE_SECONDS=3
CHANGE_REMOVAL_DEBOUNCE_SECONDS=8
CPA_REGISTRY_SYNC_INTERVAL_SECONDS=30
ACTION_BACKUP_KEEP=50
ACTION_BACKUP_MAX_AGE_DAYS=3
ACTION_BACKUP_INCLUDE_USAGE_DB=false
